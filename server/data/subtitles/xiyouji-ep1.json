    "english": "Got you! Hahaha!",
    "chinese": "抓到你了！哈哈哈！"
  },
  {
    "index": 183,
    "startTime": 1056080,
    "endTime": 1067084,
    "english": "I’m the Chaos Demon King! I am powerful!",
    "chinese": "我乃混世魔王！我最厉害！"
  },
  {
    "index": 184,
    "startTime": 1067184,
    "endTime": 1078188,
    "english": "Where is the monkey?",
    "chinese": "那猴子去哪儿了？"
  },
  {
    "index": 185,
    "startTime": 1078288,
    "endTime": 1089293,
    "english": "Ah? Where are you?",
    "chinese": "啊？你在哪儿？"
  },
  {
    "index": 186,
    "startTime": 1089393,
    "endTime": 1092865,
    "english": "Haha, I am here!",
    "chinese": "哈哈，我在这儿呢！"
