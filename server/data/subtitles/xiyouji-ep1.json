    "startTime": 997770,
    "endTime": 998367,
    "english": "Kkkkking...",
    "chinese": "大大王……"
  },
  {
    "index": 175,
    "startTime": 998467,
    "endTime": 999064,
    "english": "What’s wrong?",
    "chinese": "怎么了？"
  },
  {
    "index": 176,
    "startTime": 999164,
    "endTime": 999761,
    "english": "The monkeys have a new king! He is here!",
    "chinese": "那些猴子有了新大王！他就在这儿！"
  },
  {
    "index": 177,
    "startTime": 999861,
    "endTime": 1000458,
    "english": "Hah! How dare he?",
    "chinese": "哈？他好大的胆子！"
  },
  {
    "index": 178,
    "startTime": 1000558,
    "endTime": 1011563,
    "english": "Are you the Monkey King?",
    "chinese": "你就是那猴王？"
  },
  {
    "index": 179,
    "startTime": 1011663,
    "endTime": 1022667,
    "english": "Who are you?",
    "chinese": "你是谁？"
  },
  {
    "index": 180,
    "startTime": 1022767,
    "endTime": 1033771,
    "english": "He is the Chaos Demon King. He is powerful!",
    "chinese": "他就是混世魔王。他可厉害着呢！"
  },
  {
    "index": 181,
    "startTime": 1033871,
    "endTime": 1044876,
    "english": "You little monkey, Watch my sword!",
    "chinese": "你这小猴子，看刀！"
  },
  {
    "index": 182,
