    "endTime": 925294,
    "english": "Say no more. Go back to the Flower and Fruit mountain.",
    "chinese": "不必多说。回你的花果山去吧。"
  },
  {
    "index": 166,
    "startTime": 925394,
    "endTime": 942242,
    "english": "Okay! My friends are waiting for me. Goodbye, Master.",
    "chinese": "好吧！我的朋友们还在等我。师傅再见。"
  },
  {
    "index": 167,
    "startTime": 942342,
    "endTime": 942962,
    "english": "Our king is back! King! King!",
    "chinese": "我们的大王回来啦！大王！大王！"
  },
  {
