    "startTime": 978778,
    "endTime": 996275,
    "english": "Not good! Terrible!",
    "chinese": "不好！太糟糕了！"
  },
  {
    "index": 172,
    "startTime": 996375,
    "endTime": 996973,
    "english": "The Chaos Demon King always bullied us!",
    "chinese": "那混世魔王总是欺负我们！"
  },
  {
    "index": 173,
    "startTime": 997073,
    "endTime": 997670,
    "english": "Give me your money or give me your life!",
    "chinese": "把你们的钱财交出来，否则就取你们的性命！"
  },
  {
