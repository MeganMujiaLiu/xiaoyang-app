  {
    "index": 124,
    "startTime": 727739,
    "endTime": 731890,
    "english": "Not bad!",
    "chinese": "不错！"
  },
  {
    "index": 125,
    "startTime": 731990,
    "endTime": 736913,
    "english": "Cold night, heavy snow.",
    "chinese": "寒夜漫漫，大雪纷飞。"
  },
  {
    "index": 126,
    "startTime": 737013,
    "endTime": 742916,
    "english": "The poor little monkey has changed into a snow monkey.",
    "chinese": "那可怜的小猴儿变成了一只雪猴。"
  },
  {
    "index": 127,
    "startTime": 743016,
    "endTime": 748918,
    "english": "It’s so cold!",
    "chinese": "天气可真冷！"
  },
  {
    "index": 128,
    "startTime": 749019,
    "endTime": 756381,
    "english": "Hey! Get up！ Master wants to see you.",
    "chinese": "嘿！起来！师傅要见你。"
  },
  {
    "index": 129,
    "startTime": 756481,
    "endTime": 761682,
    "english": "Master, Master. That monkey is frozen.",
    "chinese": "师傅，师傅。那只猴子冻僵了。"
  },
  {
    "index": 130,
    "startTime": 761783,
    "endTime": 773074,
    "english": "Let me take a look.",
    "chinese": "让我瞧瞧。"
  },
  {
    "index": 131,
    "startTime": 773174,
    "endTime": 775938,
    "english": "You can be my disciple.",
    "chinese": "你可以做我的徒弟了。"
  },
  {
    "index": 132,
    "startTime": 776038,
    "endTime": 781255,
    "english": "Disciple, I will name you, Sun Wukong.",
    "chinese": "徒儿，为师给你取个名字，就叫孙悟空吧。"
  },
  {
    "index": 133,
    "startTime": 781355,
    "endTime": 784058,
    "english": "Thank you, Master! I like this name!",
    "chinese": "谢谢师傅！我喜欢这个名字！"
  },
  {
    "index": 134,
    "startTime": 784158,
    "endTime": 786360,
    "english": "Wukong, what do you want to learn?",
    "chinese": "悟空，你想学些什么本事？"
  },
  {
    "index": 135,
    "startTime": 786461,
    "endTime": 788021,
    "english": "I have no idea, Master.",
    "chinese": "徒儿不知，全凭师傅安排。"
  },
  {
    "index": 136,
    "startTime": 788121,
    "endTime": 791264,
    "english": "You can learn from Buddhist scriptures.",
    "chinese": "教你看经念佛如何？"
  },
  {
    "index": 137,
    "startTime": 791365,
    "endTime": 792446,
    "english": "No, no, no, no, no.",
    "chinese": "不要，不要，不要，不要，不要。"
  },
  {
    "index": 138,
    "startTime": 792546,
    "endTime": 794727,
    "english": "How about fortune telling?",
    "chinese": "那教你卜卦算命怎么样？"
  },
  {
    "index": 139,
    "startTime": 794827,
    "endTime": 796429,
    "english": "No, I don’t like that!",
    "chinese": "不，我不喜欢这个！"
  },
  {
    "index": 140,
    "startTime": 796529,
    "endTime": 798091,
    "english": "How about meditation?",
    "chinese": "那教你入定静坐呢？"
  },
  {
    "index": 141,
    "startTime": 798191,
    "endTime": 800853,
    "english": "Meditation? Boring! It’s too boring!",
    "chinese": "入定静坐？太无聊了！实在是太无聊了！"
  },
  {
    "index": 142,
    "startTime": 800953,
    "endTime": 808837,
    "english": "You naughty monkey! What do you want to learn?",
    "chinese": "你这猴头！到底想学些什么？"
  },
  {
    "index": 143,
    "startTime": 808937,
    "endTime": 811019,
    "english": "Master is angry with you!",
    "chinese": "师傅生你气啦！"
  },
  {
    "index": 144,
    "startTime": 811119,
    "endTime": 813139,
    "english": "Sorry, Master. I’m really sorry.",
    "chinese": "对不起师傅，徒儿真的知道错了。"
  },
  {
    "index": 145,
    "startTime": 813239,
    "endTime": 825082,
    "english": "Wukong, why are you here?",
    "chinese": "悟空，你怎么会在这儿？"
  },
  {
    "index": 146,
    "startTime": 825182,
    "endTime": 827943,
    "english": "Master, you told me to come here!",
    "chinese": "师傅，是您让我到这儿来的呀！"
  },
  {
    "index": 147,
    "startTime": 828043,
    "endTime": 830365,
    "english": "No, I didn’t.",
    "chinese": "我没有让你来。"
  },
  {
    "index": 148,
    "startTime": 830465,
    "endTime": 833985,
    "english": "Master, you tapped my head three times.",
    "chinese": "师傅，您在我头上敲了三下。"
  },
  {
    "index": 149,
    "startTime": 834086,
    "endTime": 837187,
    "english": "You want me to come here at 3!",
    "chinese": "您是想让我三点来这儿！"
  },
  {
    "index": 150,
    "startTime": 837288,
    "endTime": 842389,
    "english": "You are clever. I will teach you some skills.",
    "chinese": "哦，你倒是机灵。好吧，我就教你一些法术。"
  },
  {
    "index": 151,
    "startTime": 842490,
    "endTime": 844870,
    "english": "Thank you Master! Thank you Master!",
    "chinese": "谢谢师傅！谢谢师傅！"
  },
  {
    "index": 152,
    "startTime": 844971,
    "endTime": 859312,
    "english": "Disciple, look carefully. Let me teach you some real skills.",
    "chinese": "徒儿，你看仔细了。师傅教你些真本领。"
  },
  {
    "index": 153,
    "startTime": 859413,
    "endTime": 861256,
    "english": "Where did you go?",
    "chinese": "师傅您去哪儿了？"
  },
  {
    "index": 154,
    "startTime": 861356,
    "endTime": 864983,
    "english": "Look, this is from your Flower and Fruit mountain.",
    "chinese": "瞧，此物来自你的花果山。"
  },
  {
    "index": 155,
    "startTime": 865083,
    "endTime": 871457,
    "english": "Flower and Fruit Mountain? It’s very far!",
    "chinese": "花果山？那可远着呢！"
  },
  {
    "index": 156,
    "startTime": 871557,
    "endTime": 879061,
    "english": "This is called Somersault Cloud.",
    "chinese": "这 是 被称为 筋斗 云"
  },
  {
    "index": 157,
    "startTime": 879161,
    "endTime": 886664,
    "english": "One somersault, fifty-four thousands kilometers. Follow me!",
    "chinese": "这叫筋斗云。一个筋斗能翻十万八千里。跟着我！"
  },
  {
    "index": 158,
    "startTime": 886764,
    "endTime": 892165,
    "english": "Sun Wukong studied very hard.",
    "chinese": "孙悟空学习十分刻苦。"
  },
  {
    "index": 159,
    "startTime": 892265,
    "endTime": 899241,
    "english": "His master taught him Cloud-Somersault",
    "chinese": "他的 师傅 教了 他 筋斗云"
  },
  {
    "index": 160,
    "startTime": 899341,
    "endTime": 906317,
    "english": "and seventy-two changes.",
    "chinese": "师傅将筋斗云和七十二般变化的秘法都传授给了他。"
  },
  {
    "index": 161,
    "startTime": 906417,
    "endTime": 909198,
    "english": "Thank you Master.",
    "chinese": "谢谢师傅。"
  },
  {
    "index": 162,
    "startTime": 909298,
    "endTime": 912311,
    "english": "Wukong, you have learned real skills.",
    "chinese": "悟空，你已习得真本领。"
  },
  {
    "index": 163,
    "startTime": 912411,
    "endTime": 915423,
    "english": "It’s time for you to go home.",
    "chinese": "是时候回家去了。"
  },
  {
    "index": 164,
    "startTime": 915524,
    "endTime": 919648,
    "english": "Go home? No no, I don’t want to leave.",
    "chinese": "回家？不，不，我不想离开。"
  },
  {
    "index": 165,
