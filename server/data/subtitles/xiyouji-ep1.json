    "english": "Itchy! Itchy! Haaahhaha",
    "chinese": "痒！好痒啊！哈哈哈"
  },
  {
    "index": 188,
    "startTime": 1096538,
    "endTime": 1100010,
    "english": "It’s our king！",
    "chinese": "这是我们的大王！"
  },
  {
    "index": 189,
    "startTime": 1100110,
    "endTime": 1103583,
    "english": "Yes, our king！",
    "chinese": "是的 我们的 大王"
  },
  {
    "index": 190,
    "startTime": 1103683,
    "endTime": 1107155,
    "english": "Our King!",
    "chinese": "没错，是我们的大王！"
  },
  {
    "index": 191,
    "startTime": 1107255,
    "endTime": 1110728,
    "english": "Hahahahahahah， Itchy! So itchy!",
    "chinese": "哈哈哈……痒！太痒了！"
  },
  {
    "index": 192,
    "startTime": 1110828,
    "endTime": 1114301,
    "english": "Leave Flower and Fruit mountain!",
    "chinese": "离开花果山！"
  },
  {
    "index": 193,
    "startTime": 1114401,
    "endTime": 1117873,
    "english": "Never come back!",
    "chinese": "永远别再回来！"
  },
  {
    "index": 194,
    "startTime": 1117973,
    "endTime": 1121446,
    "english": "Cheers! Cheers! Cheers! Great King! Great King!",
    "chinese": "干杯！干杯！干杯！大王万岁！大王万岁！"
  },
  {
    "index": 195,
    "startTime": 1121546,
    "endTime": 1125019,
    "english": "From now on, no one will bully us again!",
    "chinese": "从现在起，再也没人敢欺负我们了！"
  },
  {
    "index": 196,
    "startTime": 1125118,
    "endTime": 1126019,
    "english": "We are safe for now, but we still need some good weapons.",
    "chinese": "我们现在暂时安全了，但还需要一些好武器防身。"
  },
  {
    "index": 197,
    "startTime": 1126118,
    "endTime": 1127019,
    "english": "Good weapons? You are right! I’ll go get some!",
    "chinese": "好武器？你说得对！我这就去寻些来！"
  },
  {
    "index": 198,
    "startTime": 1127118,
    "endTime": 1134125,
    "english": "Bye! Good-bye! Bye! Take care!",
    "chinese": "再见！再见！再见！保重！"
  }
