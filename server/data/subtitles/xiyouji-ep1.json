    "endTime": 943483,
    "english": "Our king is back!",
    "chinese": "我们的大王回来啦！"
  },
  {
    "index": 169,
    "startTime": 943583,
    "endTime": 961081,
    "english": "King! King!",
    "chinese": "大王！大王！"
  },
  {
    "index": 170,
    "startTime": 961181,
    "endTime": 978678,
    "english": "I miss you all. How have you been?",
    "chinese": "我好想你们啊。你们一向可好？"
  },
  {
