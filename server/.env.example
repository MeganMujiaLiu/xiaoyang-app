# Base URL this server is reachable at — used to build video URLs returned by /api/videos
# Local dev: http://localhost:8000
# Production: https://cdn.yourdomain.com  (swap to CDN when videos move to OSS)
SERVER_BASE_URL=http://localhost:8000

# iFlytek credentials (only needed for POST /api/score)
IFLYTEK_APPID=your_appid_here
IFLYTEK_API_KEY=your_api_key_here

PORT=8000
